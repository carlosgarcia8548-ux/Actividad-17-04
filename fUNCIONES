#include <stdio.h>
#include <stdlib.h>
void capturar(int m[3][3]){
    for(int i=0; i<3; i++){
        for(int j=0; j<3;j++){
            scanf("%d", &m[i][j]);
        }
    }
}
void mostrar(int m[3][3]){
    for(int i=0; i<3; i++){
        for(int j=0; j<3;j++){
            printf("%d\n", m[i][j]);
        }
        printf("\n");
    }
}
int diagonal(int m[3][3]){
    int i, suma=0;
        for(i=0;i<3;i++){
            suma+= m[i][i];
        }
        return suma;
}
